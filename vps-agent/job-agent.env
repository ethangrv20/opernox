# Opernox VPS Agent — Environment Variables
# Copy this file to .env and fill in your values

# Supabase project URL
SUPABASE_URL=https://ujdegmhsvwymxzezwwna.supabase.co

# Supabase SERVICE ROLE key (NOT the anon key — this can write to restricted tables)
# Get it from: Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_KEY=your_service_role_key_here

# Unique ID for this VPS agent
VPS_ID=vps-ethan-primary

# User ID in Supabase (profiles.id) — the account this VPS belongs to
# For single-user mode, set this. Leave blank for multi-user poll mode.
USER_ID=your_user_id_here

# Mission Control server (usually localhost on the same VPS)
MC_HOST=127.0.0.1
MC_PORT=3337

# How often to poll Supabase for new jobs (milliseconds)
POLL_INTERVAL_MS=15000
